        "${workspaceFolder}/Services/Inc",
        "${workspaceFolder}/Platform/Inc",
        "${workspaceFolder}/Platform/Port",
        "${workspaceFolder}/Device/Inc",
        "${workspaceFolder}/Drivers/STM32F4xx_HAL_Driver/Inc",
        "${workspaceFolder}/Drivers/STM32F4xx_HAL_Driver/Inc/Legacy",
        "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32F4xx/Include",
        "${workspaceFolder}/Drivers/CMSIS/Include",
        "${workspaceFolder}/Vendor/FreeRTOS/Source/include",
        "${workspaceFolder}/Vendor/FreeRTOS/Source/portable/GCC/ARM_CM4F",
