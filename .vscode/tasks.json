{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Refresh IntelliSense DB",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/build.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/build.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Warm GDB",
      "type": "shell",
      "command": "C:/PROGRA~1/Arm/GNUTOO~1/bin/AR470E~1.EXE",
      "args": [
        "-q",
        "--batch",
        "-nx",
        "-ex",
        "quit"
      ],
      "problemMatcher": []
    },
    {
      "label": "Prepare Debug",
      "dependsOn": [
        "Build Debug",
        "Warm GDB"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Clean Debug",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/build.ps1",
        "-Clean"
      ],
      "problemMatcher": []
    },
    {
      "label": "Flash",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/flash.ps1"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
